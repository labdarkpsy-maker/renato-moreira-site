---
import "../styles/main.css";

const {
  title = "Renato Moreira",
  description = "Renato Moreira – Lisbon-born, Porto-based. Music producer, live performer, sound & AV specialist."
} = Astro.props;
// current page path (e.g. /music, /teaching, /timeline)
const path = Astro.url.pathname;

// helper to check if a nav link is active
const isActive = (href: string) =>
  path === href || path.startsWith(href + "/");

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / WhatsApp / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://renato-moreira-site.pages.dev${path}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://renato-moreira-site.pages.dev/renato-portrait-v2.webp" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://renato-moreira-site.pages.dev/renato-portrait-v2.webp" />
  </head>

  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href="/">Renato Moreira</a>
        <nav class="nav">
          <a class={isActive("/about") ? "active" : ""} href="/about">About</a>
          <a class={isActive("/music") ? "active" : ""} href="/music">Music</a>
          <a class={isActive("/technical-av") ? "active" : ""} href="/technical-av">Technical & AV</a>
          <a class={isActive("/web-presence") ? "active" : ""} href="/web-presence">Web Presence</a>
          <a class={isActive("/teaching") ? "active" : ""} href="/teaching">Teaching</a>
          <a class={isActive("/timeline") ? "active" : ""} href="/timeline">Timeline</a>
          <a class={isActive("/contact") ? "active" : ""} href="/contact">Contact</a>
       
        </nav>        
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>© {new Date().getFullYear()} Renato Moreira</div>
        <div class="footer-links">
          <a href="https://soundcloud.com/renlab" target="_blank" rel="noreferrer">SoundCloud</a>
          <a href="https://labdark.bandcamp.com/" target="_blank" rel="noreferrer">Bandcamp</a>
          <a href="https://www.youtube.com/@labbosmerandunikorp1030" target="_blank" rel="noreferrer">YouTube</a>
        </div>
      </div>
    </footer>
  </body>
</html>
